FROM python:3.11-slim

ENV PYTHONUNBUFFERED=1
ENV PYTHONDONTWRITEBYTECODE=1

RUN useradd --create-home --shell /bin/bash appuser
WORKDIR /app

COPY requirements.txt /app/requirements.txt
RUN pip install --no-cache-dir -r /app/requirements.txt

COPY config.py /app/config.py
COPY main.py /app/main.py
COPY run_api.py /app/run_api.py
COPY engine /app/engine
COPY services /app/services
COPY static /app/static
COPY templates /app/templates

USER appuser

HEALTHCHECK --interval=30s --timeout=5s --start-period=20s --retries=3 CMD python -c "import os, urllib.request; urllib.request.urlopen(f'http://127.0.0.1:{os.getenv(\"PORT\", \"8002\")}/health/ready', timeout=3)"

CMD ["python", "run_api.py"]
