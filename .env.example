# GitHub App settings
GITHUB_APP_ID=your_github_app_id
GITHUB_PRIVATE_KEY_PATH=../your-github-app.private-key.pem
GITHUB_APP_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=your_webhook_secret
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
GITHUB_OAUTH_CALLBACK_URL=

# DriftGuard app settings
APP_BASE_URL=http://127.0.0.1:8000
APP_ENCRYPTION_KEY=
SESSION_COOKIE_NAME=promptdrift_session
SESSION_COOKIE_SECURE=false
SESSION_TTL_SECONDS=604800

# Azure OpenAI / Foundry credentials
OPENAI_API_KEY=
FOUNDRY_API_KEY=your_foundry_or_azure_openai_key
FOUNDRY_PROJECT_ENDPOINT=https://your-foundry-project.services.ai.azure.com/api/projects/your-project
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/openai/v1
AI_MODEL=gpt-4o

# Cloud deployment settings
DATABASE_URL=sqlite:///./promptdrift.db
AUDIT_DB_PATH=./promptdrift.db
QUEUE_BACKEND=sqlite
SQS_QUEUE_URL=
SQS_DLQ_URL=
REDIS_URL=
API_ADMIN_TOKEN=
ENABLE_METRICS=false
WORKER_CONCURRENCY=4
WORKER_MAX_RETRIES=3
WORKER_METRICS_PORT=8003

# Stripe billing settings
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PORTAL_CONFIGURATION_ID=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_TEAM=
STRIPE_PRICE_ENTERPRISE=
STRIPE_PRICE_BUSINESS=

# Optional local testing credentials
GITHUB_PAT=
NGROK_AUTHTOKEN=
