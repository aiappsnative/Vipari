{
  "mcpServers": {
    "vipari": {
      "command": "python",
      "args": ["vipari_mcp_server.py"],
      "env": {
        "VIPARI_MCP_BROKER_URL": "{{VIPARI_MCP_BROKER_URL}}",
        "VIPARI_CLIENT_ID": "replace-with-your-client-id",
        "VIPARI_CLIENT_SECRET": "replace-with-your-client-secret"
      }
    }
  }
}